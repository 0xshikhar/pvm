# Example TeleBasket config (no secrets)
# Copy to `.env` and update contract addresses.

VITE_NETWORK=paseo
VITE_RPC_URL=https://eth-rpc-testnet.polkadot.io
VITE_CHAIN_ID=420420417
VITE_GAS_PRICE_GWEI=1100

VITE_BASKET_MANAGER_ADDRESS=0x0000000000000000000000000000000000000000
VITE_PVM_ENGINE_ADDRESS=0x0000000000000000000000000000000000000000
VITE_USE_MOCK_PVM=true

# Frontend network selection: `paseo` (default) or `westend`
VITE_NETWORK=paseo

# EVM RPC + chain id
VITE_RPC_URL=https://eth-rpc-testnet.polkadot.io
VITE_CHAIN_ID=420420417
VITE_GAS_PRICE_GWEI=1100

# Contracts
VITE_BASKET_MANAGER_ADDRESS=
VITE_PVM_ENGINE_ADDRESS=

# PVM (set true if you don't have a deployed engine contract)
VITE_USE_MOCK_PVM=true
