# TeleBasket Environment Configuration

# Network Configuration
VITE_CHAIN_ID=31337
VITE_RPC_URL=http://127.0.0.1:8545

# Contract Addresses (Update after running pnpm run deploy:local)
VITE_BASKET_MANAGER_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3
VITE_PVM_ENGINE_ADDRESS=0x0000000000000000000000000000000000000900

# PVM Configuration
# Set to 'true' for local testing with mock PVM
# Set to 'false' when PVM is deployed on-chain
VITE_USE_MOCK_PVM=true

# Feature Flags
VITE_ENABLE_REBALANCING=true
VITE_ENABLE_XCM=true

# Testnet Configuration (when not using local)
# VITE_CHAIN_ID=420420421
# VITE_RPC_URL=https://westend-asset-hub-eth-rpc.polkadot.io
